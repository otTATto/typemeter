{
  "name": "typemeter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare": "husky",
    "lint": "eslint src/",
    "lint:style": "stylelint \"src/**/*.vue\"",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "oxfmt": "^0.47.0",
    "postcss-html": "^1.8.0",
    "stylelint": "^16.19.1",
    "stylelint-config-standard": "^38.0.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix"
    ],
    "*.{css,vue}": [
      "stylelint --fix"
    ],
    "*.{js,vue,json,css,md}": [
      "oxfmt --write"
    ]
  }
}
