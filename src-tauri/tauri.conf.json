{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "typemeter",
  "version": "0.1.0-beta.2",
  "identifier": "com.taish.typemeter",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "typemeter",
        "width": 1000,
        "height": 870,
        "minWidth": 680,
        "minHeight": 200,
        "visible": false
      },
      {
        "label": "about",
        "title": "About typemeter",
        "url": "about.html",
        "width": 480,
        "height": 400,
        "resizable": false,
        "visible": false,
        "center": true
      },
      {
        "label": "settings",
        "title": "Settings",
        "url": "settings.html",
        "width": 480,
        "height": 240,
        "resizable": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "version": "0.1.0.2"
      }
    }
  }
}
